<section class="register" aria-labelledby="registerTitle">
    <div class="register__card">
        <p class="register__tag">EAAM</p>
        <h1 id="registerTitle" class="register__title">Register to Continue</h1>
        <p class="register__description">Please enter your details to access the bidding home page.</p>

        <form id="registerForm" class="register__form" novalidate>
            <label for="firstName" class="register__label">First name</label>
            <input id="firstName" name="firstName" type="text" class="register__input" autocomplete="given-name" required>

            <label for="lastName" class="register__label">Last name</label>
            <input id="lastName" name="lastName" type="text" class="register__input" autocomplete="family-name" required>

            <label for="email" class="register__label">Email address</label>
            <input id="email" name="email" type="email" class="register__input" autocomplete="email" required>

            <button type="submit" class="register__submit">Continue to bidding</button>
            <p id="registerError" class="register__error" role="alert" aria-live="polite"></p>
        </form>
    </div>
</section>

<script src="/js/register.js" defer></script>
